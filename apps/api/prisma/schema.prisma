generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  pending
  processing
  completed
  failed
}

enum TokenPurchaseStatus {
  pending
  completed
}

enum PaymentProvider {
  stripe
  crypto
}

model BillingAccount {
  id               String               @id @default(cuid())
  userId           String               @unique
  tokenBalance     Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  purchases        TokenPurchase[]
  paymentProfiles  BillingPaymentProfile[]
}

model BillingPaymentProfile {
  id                 String          @id @default(cuid())
  billingAccountId   String
  provider           PaymentProvider
  providerCustomerId String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  billingAccount     BillingAccount  @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@unique([provider, providerCustomerId])
  @@unique([billingAccountId, provider])
}

model TokenPurchase {
  id                String              @id @default(cuid())
  billingAccountId  String
  provider          PaymentProvider
  providerSessionId String              @unique
  providerPaymentId String?
  packageId         String
  currencyCode      String
  amountMinor       Int
  tokenAmount       Int
  status            TokenPurchaseStatus @default(pending)
  metadata          Json?
  createdAt         DateTime            @default(now())
  completedAt       DateTime?
  billingAccount    BillingAccount      @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
}

model Photo {
  id           String   @id @default(cuid())
  userId       String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]
}

model Job {
  id             String            @id @default(cuid())
  userId         String
  photoId        String
  status         JobStatus         @default(pending)
  progress       Int               @default(0)
  errorMessage   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?
  photo          Photo             @relation(fields: [photoId], references: [id], onDelete: Cascade)
  processedAsset ProcessedAsset?
  arweaveUpload  ArweaveUpload?
}

model ProcessedAsset {
  id          String   @id @default(cuid())
  jobId       String   @unique
  storagePath String
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ArweaveUpload {
  id            String   @id @default(cuid())
  jobId         String   @unique
  transactionId String   @unique
  ownerAddress  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
